+import ray
+import numpy as np
+import random
+import copy
+
+@ray.remote
+class SelfPlayManager:
+    """
+    Gestionnaire centralis笏慊ｮ pour le League Training.
+    Stocke les snapshots historiques du mod笏慊ｿle et fournit des adversaires.
+    """
+    def __init__(self, max_history=50):
+        self.history = []
+        self.max_history = max_history
+
+    def add_snapshot(self, params):
+        """Ajoute un snapshot de poids dans l'historique."""
+        # On copie profond笏慊ｮment pour 笏慊ｮviter les mutations
+        # params est un PyTree de ndarrays JAX. copy.deepcopy fonctionne g笏慊ｮn笏慊ｮralement.
+        # Mais pour 笏慊ｬtre s笏懌風r avec JAX, on peut juste stocker la r笏慊ｮf笏慊ｮrence si le Learner 
+        # recr笏慊ｮe un nouvel arbre 笏愿｡ chaque update, ce qui est le cas avec optax.
+        self.history.append(params)
+        if len(self.history) > self.max_history:
+            self.history.pop(0)
+            
+        print(f"[SelfPlayManager] Snapshot ajout笏慊ｮ. Taille de l'historique: {len(self.history)}")
+
+    def get_opponent(self, latest_params):
+        """
+        Retourne les poids d'un adversaire.
+        50% du temps le mod笏慊ｿle le plus r笏慊ｮcent (latest_params),
+        50% du temps un mod笏慊ｿle historique al笏慊ｮatoire.
+        """
+        if not self.history or random.random() < 0.5:
+            return latest_params
+            
+        idx = random.randint(0, len(self.history) - 1)
+        return self.history[idx]
+        
+    def get_history_size(self):
+        return len(self.history)
