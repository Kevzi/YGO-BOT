+import ray
+import numpy as np
+import jax.numpy as jnp
+from core.ygoenv.env import YgoEnv
+from ai.ppo import PPOAgent
+
+@ray.remote
+class RolloutWorker:
+    def __init__(self, obs_dim: int = 100, act_dim: int = 200, hidden_dim: int = 64):
+        # Initialise l'environnement ├á l'int├®rieur de l'acteur (CPU/Thread local)
+        self.env = YgoEnv()
+        self.agent = PPOAgent(obs_dim=obs_dim, act_dim=act_dim, hidden_dim=hidden_dim)
+
+    def collect_rollout(self, params: dict, num_steps: int = 100) -> dict:
+        """
+        Joue 'num_steps' ├®tapes dans l'environnement en utilisant les poids (params) du Learner.
+        Retourne la trajectoire (batch).
+        """
+        obs_list = []
+        actions_list = []
+        rewards_list = []
+        log_probs_list = []
+        values_list = []
+
+        obs, _ = self.env.reset()
+
+        # Si params est vide (pour le test mock par exemple), on init dummy params
+        import jax
+        if not params:
+            rng = jax.random.PRNGKey(0)
+            params = self.agent.init_params(rng)
+
+        for _ in range(num_steps):
+            obs_jax = jnp.array(obs)
+            
+            # Forward pass (Policy et Value)
+            probs, value = self.agent.forward(params, obs_jax)
+            
+            # ├ëchantillonnage de l'action selon les probabilit├®s
+            probs_np = np.array(probs)
+            # Si le mod├¿le retourne un batch de taille 1, on extrait le vecteur
+            if probs_np.ndim == 2 and probs_np.shape[0] == 1:
+                probs_np = probs_np[0]
+            # S├®curit├® (NaN)
+            if np.isnan(probs_np).any():
+                probs_np = np.ones_like(probs_np) / len(probs_np)
+                
+            action = np.random.choice(len(probs_np), p=probs_np)
+            
+            # Enregistrement pour l'apprentissage
+            obs_list.append(obs)
+            actions_list.append(action)
+            
+            # log_prob approxim├® (pour PPO old_log_probs)
+            log_prob = np.log(probs_np[action] + 1e-8)
+            log_probs_list.append(log_prob)
+            values_list.append(float(np.squeeze(value)))
+
+            # Step dans l'environnement
+            next_obs, reward, terminated, truncated, info = self.env.step(action)
+            rewards_list.append(reward)
+
+            if terminated or truncated:
+                obs, _ = self.env.reset()
+            else:
+                obs = next_obs
+
+        # Calcul basique de 'returns' et 'advantages' pour le mock (on laisse le Learner faire le calcul pr├®cis avec GAE normalement, 
+        # mais ici on simplifie pour retourner un dict complet)
+        rewards_np = np.array(rewards_list, dtype=np.float32)
+        values_np = np.array(values_list, dtype=np.float32)
+        
+        # Un returns mock├® simple : R_t = r_t + gamma * V_{t+1} (gamma=0.99)
+        returns_np = rewards_np + 0.99 * np.append(values_np[1:], 0.0)
+        advantages_np = returns_np - values_np
+
+        return {
+            "obs": np.array(obs_list, dtype=np.float32),
+            "actions": np.array(actions_list, dtype=np.int32),
+            "rewards": rewards_np,
+            "old_log_probs": np.array(log_probs_list, dtype=np.float32),
+            "values": values_np,
+            "returns": returns_np,
+            "advantages": advantages_np
+        }
