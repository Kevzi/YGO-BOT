+import ray
+from db.session import get_db
+from db.models import DuelStats
+
+@ray.remote
+class DatabaseActor:
+    def __init__(self):
+        # Initialisation (pourrait pr├®charger la session DB)
+        pass
+
+    def record_duel_stats(self, stats_dict: dict) -> bool:
+        """
+        Enregistre les stats d'un duel de mani├¿re s├®quentielle pour ├®viter
+        les erreurs 'database is locked' de SQLite.
+        """
+        try:
+            db_generator = get_db()
+            db = next(db_generator)
+            
+            # Simple insertion
+            duel_stat = DuelStats(**stats_dict)
+            db.add(duel_stat)
+            db.commit()
+            return True
+        except Exception as e:
+            print(f"Erreur d'insertion DB: {e}")
+            return False
+        finally:
+            # On s'assure de fermer la session
+            try:
+                next(db_generator)
+            except StopIteration:
+                pass
