++@ray.remote
++class RolloutWorker:
++    def __init__(self, obs_dim: int = 100, act_dim: int = 200, hidden_dim: int = 64, use_mcts: bool = True, num_simulations: int = 8):
++        # Initialise l'environnement Ôö£├í l'intÔö£┬«rieur de l'acteur (CPU/Thread local)
++        self.env = YgoEnv()
