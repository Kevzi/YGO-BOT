++import os
++import pickle
++import logging
++import jax.numpy as jnp
++import numpy as np
++
++logger = logging.getLogger(__name__)
++
++class EmbeddingError(Exception):
++    """Exception levÔö£┬«e pour les erreurs liÔö£┬«es au chargement des embeddings."""
++    pass
++
++class EmbeddingLoader:
++    def __init__(self, filepath: str = "data/embed.pkl"):
++        self.filepath = filepath
++        self._embeddings_dict = None
++        self._embedding_dim = None
++
++    def load(self):
++        """DÔö£┬«sÔö£┬«rialise et charge le dictionnaire d'embeddings en mÔö£┬«moire vive."""
++        if not os.path.exists(self.filepath):
++            raise EmbeddingError(f"Le fichier d'embeddings est introuvable : {self.filepath}")
++
++        try:
++            with open(self.filepath, "rb") as f:
++                data = pickle.load(f)
++                
++            if not isinstance(data, dict):
++                raise EmbeddingError(f"Le fichier {self.filepath} doit contenir un dictionnaire Python.")
++                
++            # Convert values to JAX arrays to avoid dict -> numpy -> jax overhead during inference
++            self._embeddings_dict = {}
++            for card_id, vector in data.items():
++                jax_vector = jnp.asarray(vector, dtype=jnp.float32)
++                self._embeddings_dict[int(card_id)] = jax_vector
++                
++                if self._embedding_dim is None:
++                    self._embedding_dim = jax_vector.shape[0]
++                    
++            logger.info(f"Loaded {len(self._embeddings_dict)} card embeddings from {self.filepath} into memory.")
++        except Exception as e:
++            if isinstance(e, EmbeddingError):
++                raise
++            raise EmbeddingError(f"Erreur lors de la dÔö£┬«sÔö£┬«rialisation de {self.filepath}: {e}")
++
++    def is_loaded(self) -> bool:
++        """Indique si les embeddings sont chargÔö£┬«s."""
++        return self._embeddings_dict is not None
++
++    def get_embedding(self, card_id: int) -> jnp.ndarray:
++        """Retourne l'embedding JAX pour un ID de carte. O(1)."""
++        if not self.is_loaded():
++            raise EmbeddingError("Les embeddings n'ont pas Ôö£┬«tÔö£┬« chargÔö£┬«s. Appelez load() d'abord.")
++            
++        if card_id in self._embeddings_dict:
++            return self._embeddings_dict[card_id]
++        else:
++            # Fallback for unknown cards: Zero-shot requires returning a zero vector
++            return jnp.zeros((self._embedding_dim,), dtype=jnp.float32)
++
++    def get_embeddings_batch(self, card_ids: jnp.ndarray) -> jnp.ndarray:
++        """Retourne un batch d'embeddings pour un tableau d'IDs."""
++        if not self.is_loaded():
++            raise EmbeddingError("Les embeddings n'ont pas Ôö£┬«tÔö£┬« chargÔö£┬«s.")
++            
++        card_ids_np = np.asarray(card_ids)
++        vectors = []
++        for cid in card_ids_np:
++            cid_int = int(cid)
++            if cid_int in self._embeddings_dict:
++                vectors.append(self._embeddings_dict[cid_int])
++            else:
++                vectors.append(jnp.zeros((self._embedding_dim,), dtype=jnp.float32))
++                
++        return jnp.stack(vectors)
++
++# Global instance for the API
++embed_loader = EmbeddingLoader()
