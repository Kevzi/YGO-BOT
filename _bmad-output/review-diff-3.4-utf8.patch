++
++class DummyAgent:
++    """
++    A temporary agent for testing the end-to-end loop.
++    It simply chooses a random legal action.
++    """
++    
++    def select_action(self, legal_actions: List[Dict[str, Any]]) -> Dict[str, Any]:
++        """
