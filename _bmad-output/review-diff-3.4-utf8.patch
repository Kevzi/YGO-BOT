++class YgoEnv(gym.Env):
++    """
++    Environnement Gym standardisÔö£┬« encapsulant le moteur C++ (ocgcore) via YgoEngine.
++    """
++    
++    def __init__(self):
++        super(YgoEnv, self).__init__()
++        
++        # Dimensions pour le MVP:
++        # - Action space: par exemple 200 actions discrÔö£┬┐tes possibles (id de l'action)
++        self.action_space = gym.spaces.Discrete(200)
++        
++        # - Observation space: tenseur plat float32 de taille fixe (ex: 100) reprÔö£┬«sentant le terrain
++        self.observation_space = gym.spaces.Box(low=-1.0, high=1.0, shape=(100,), dtype=np.float32)
++        
++        self.engine = YgoEngine()
++        self._current_state = None
++        
++    def _get_observation(self) -> np.ndarray:
++        # TODO: Appeler l'engine pour extraire le vrai terrain
++        # MVP: retourner un tableau rempli de zÔö£┬«ros
++        return np.zeros(self.observation_space.shape, dtype=np.float32)
++        
++    def reset(self, seed=None, options=None) -> tuple[np.ndarray, dict]:
++        super().reset(seed=seed, options=options)
++        
++        # Initialiser un duel ou rÔö£┬«initialiser l'Ôö£┬«tat
++        self._current_state = {"phase": "DRAW", "turn": 1}
++        
++        # Validation via le moteur (mock)
++        _ = self.engine.get_legal_actions(self._current_state)
++        
++        obs = self._get_observation()
++        info = {}
++        
++        return obs, info
++        
++    def step(self, action: int) -> tuple[np.ndarray, float, bool, bool, dict]:
++        if self._current_state is None:
++            raise RuntimeError("L'environnement doit Ôö£┬¼tre rÔö£┬«initialisÔö£┬« via reset() avant le premier step().")
++            
++        if not self.action_space.contains(action):
++            raise ValueError(f"Action invalide: {action}")
++            
++        # Appliquer l'action au state
++        self._current_state["last_action"] = action
++        
++        # Valider et obtenir les prochaines actions via le moteur
++        # (Fail Fast: les erreurs EngineCrashError se propagent naturellement)
++        legal_actions = self.engine.get_legal_actions(self._current_state)
++            
++        # Simuler un passage au tour suivant ou fin de partie
++        obs = self._get_observation()
++        reward = 0.0
++        terminated = False
++        truncated = False
++        info = {"legal_actions": legal_actions}
++        
++        return obs, reward, terminated, truncated, info
++
++    def save_state(self) -> dict:
++        """Sauvegarde l'Ôö£┬«tat complet du duel (clone) pour le MCTS."""
++        # Dans le MVP sans ocgcore complet, on copie le dictionnaire d'Ôö£┬«tat
++        import copy
++        return copy.deepcopy(self._current_state)
++
++    def restore_state(self, state: dict):
++        """Restaure un Ôö£┬«tat sauvegardÔö£┬« du duel."""
++        import copy
++        self._current_state = copy.deepcopy(state)
