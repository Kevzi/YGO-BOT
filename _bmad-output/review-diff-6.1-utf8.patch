@@ -0,0 +1,55 @@
+import jax.numpy as jnp
+import flax.linen as nn
+
+class ActorCriticLSTM(nn.Module):
+    """
+    Réseau de neurones Actor-Critic avec LSTM pour PPO.
+    Prend en charge l'observation de 60694 dimensions, compresse avec un encodeur,
+    maintient un état de croyance (belief state) via un LSTM,
+    et masque les actions illégales.
+    """
+    act_dim: int = 200
+    hidden_dim: int = 512
+
+    @nn.compact
+    def __call__(self, carry: tuple[jnp.ndarray, jnp.ndarray], obs: jnp.ndarray, action_mask: jnp.ndarray):
+        """
+        Inférence sur un seul pas de temps (single step).
+        
+        Args:
+            carry: Tuple d'états cachés (h, c) pour le LSTM.
+            obs: Tenseur d'observations de forme (batch, obs_dim).
+            action_mask: Tenseur booléen de forme (batch, act_dim).
+            
+        Returns:
+            new_carry: Tuple mis à jour (h', c').
+            logits: Les probabilités brutes d'actions (avant softmax) avec masking.
+            value: La valeur estimée de l'état (critic).
+        """
+        # 1. Encodeur Spatial (Feature Extractor)
+        # Compresse l'immense vecteur d'observation
+        x = nn.Dense(self.hidden_dim, name="encoder")(obs)
+        x = nn.relu(x)
+        
+        # 2. Cœur Récurrent (LSTM - Belief State)
+        # Mémorise les informations cachées et le contexte passé
+        lstm_cell = nn.LSTMCell(features=self.hidden_dim, name="lstm")
+        new_carry, h_out = lstm_cell(carry, x)
+        
+        # 3. Têtes de sortie (Heads)
+        # Tête Critique (Value)
+        value = nn.Dense(1, name="critic")(h_out)
+        
+        # Tête Acteur (Policy Logits)
+        logits = nn.Dense(self.act_dim, name="actor")(h_out)
+        
+        # Action Masking : appliquer -1e9 aux actions illégales avant le Softmax
+        # JAX `where` utilise le masque (True = légal, False = illégal)
+        logits = jnp.where(action_mask, logits, -1e9)
+        
+        return new_carry, logits, value
+
+def init_hidden_state(batch_size: int, hidden_dim: int = 512) -> tuple[jnp.ndarray, jnp.ndarray]:
+    """Initialise l'état caché (h, c) du LSTM pour un batch."""
+    return (jnp.zeros((batch_size, hidden_dim), dtype=jnp.float32),
+            jnp.zeros((batch_size, hidden_dim), dtype=jnp.float32))
